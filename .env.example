DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/pitchsim
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/pitchsim
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=google/gemini-2.5-flash

# Multi-model pool (leave blank to use single model above)
# Tier 1 = premium: C-suite personas, budget holders, interactive chat
# Tier 2 = volume: bulk persona simulations
# All models route through OpenRouter — use any model available there
OPENROUTER_MODEL1_ID=google/gemini-2.5-flash
OPENROUTER_MODEL2_ID=google/gemini-2.5-flash
OPENROUTER_MODEL3_ID=google/gemini-2.5-flash
OPENROUTER_MODEL4_ID=google/gemini-2.5-flash
OPENROUTER_MODEL5_ID=google/gemini-2.5-flash
OPENROUTER_CONCURRENCY_PER_MODEL=10
REDIS_URL=redis://redis:6379/0

# MiroFish — Swarm Intelligence Engine (core simulation backend)
# MiroFish spawns thousands of autonomous AI agents that simulate buyer behavior.
# See: https://github.com/666ghj/MiroFish
MIROFISH_API_URL=http://mirofish:5001
MIROFISH_NUM_AGENTS=50
MIROFISH_NUM_ROUNDS=20

# MiroFish's own LLM config (used by its internal agents)
# These are passed to the MiroFish container via its own .env
# LLM_API_KEY=your_openrouter_key
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL_NAME=openai/gpt-4o-mini
# ZEP_API_KEY=your_zep_cloud_key

DEBUG=false
