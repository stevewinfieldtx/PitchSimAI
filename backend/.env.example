DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/pitchsim
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/pitchsim
SECRET_KEY=change-me-to-a-real-secret-key
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# Multi-model pool (leave blank to use single model above)
# Tier 1 = premium: C-suite personas, budget holders, interactive chat
# Tier 2 = volume: bulk persona simulations
OPENROUTER_MODEL1_ID=anthropic/claude-sonnet-4
OPENROUTER_MODEL2_ID=openai/gpt-4o
OPENROUTER_MODEL3_ID=openai/gpt-4o-mini
OPENROUTER_MODEL4_ID=meta-llama/llama-3.1-70b-instruct
OPENROUTER_MODEL5_ID=google/gemini-flash-1.5
OPENROUTER_CONCURRENCY_PER_MODEL=10
REDIS_URL=redis://redis:6379/0
MIROFISH_API_URL=http://localhost:8080
DEBUG=false
